{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(specify init:*)",
      "Bash(uvx:*)",
      "Bash(specify:*)",
      "Bash(curl -s https://api.github.com/repos/github/spec-kit/releases/latest)",
      "Bash(curl -I https://github.com/github/spec-kit/releases/tag/templates-2025-08-25)",
      "Bash(cp Kimi_Agent_SpecKit/*.md .specify/memory/)",
      "Bash(cp Kimi_Agent_SpecKit/*.ts .specify/memory/)",
      "Bash(cp Kimi_Agent_SpecKit/*.mmd .specify/memory/)",
      "Bash(cp:*)",
      "Bash(code --list-extensions)",
      "Bash(.specify/templates/README.md:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(.specify/scripts/powershell/create-new-feature.ps1:*)",
      "Bash(bash:*)",
      "Bash(powershell.exe:*)",
      "Bash(timeout 10s pnpm dev)",
      "WebFetch(domain:www.radix-vue.com)",
      "WebFetch(domain:quasar.dev)",
      "Bash(pnpm add:*)",
      "Bash(pnpm dev:*)",
      "Bash(npx kill-port:*)"
    ]
  }
}
